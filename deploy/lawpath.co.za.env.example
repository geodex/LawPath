# LawPath production environment for lawpath.co.za
# Copy this file to /home2/lawpath/app/LawPath/.env on the server.
# Do not commit the real .env file.

PORT=3069
NODE_ENV=production

VITE_APP_NAME=LawPath SA
VITE_APP_URL=https://lawpath.co.za

# Leave blank when Apache proxies https://lawpath.co.za/api to http://127.0.0.1:3069/api
VITE_API_BASE_URL=
CORS_ORIGIN=https://lawpath.co.za

# Replace YOUR_DATABASE_PASSWORD with the live PostgreSQL password on the server.
DATABASE_URL=postgresql://lawpath:YOUR_DATABASE_PASSWORD@127.0.0.1:5432/lawpath

# Generate a long random value on the server, for example:
# openssl rand -base64 48
SESSION_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Platform SMTP transport. Tenant sender identity stays tenant-specific in the database.
SMTP_HOST=smtp.example.co.za
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=notifications@lawpath.co.za
SMTP_PASSWORD=replace_with_smtp_password
SMTP_FROM_EMAIL=notifications@lawpath.co.za
SMTP_FROM_NAME=LawPath SA

# Super-admin-only provider keys. Keep real values on the server only.
OPENAI_API_KEY=replace_on_server
GEMINI_API_KEY=replace_on_server
GROK_API_KEY=replace_on_server
EXCHANGERATES_API_KEY=replace_on_server

# Google Cloud Storage for all tenant logos, documents, media and AI training data.
# Keep the service-account JSON outside public_html and outside Git.
GCS_BUCKET_NAME=lawpath-ai-training
GEMINI_GCS_BUCKET_NAME=lawpath-ai-training
GOOGLE_CLOUD_PROJECT=replace_with_google_cloud_project_id
GOOGLE_APPLICATION_CREDENTIALS=/home2/lawpath/secure/gcp-service-account.json
GCS_SIGNED_URLS=true
# Optional if serving through a public bucket/CDN:
# GCS_PUBLIC_BASE_URL=https://storage.googleapis.com/lawpath-ai-training
