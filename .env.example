# Frontend public configuration.
# Values prefixed with VITE_ are bundled into the browser build, so never put secrets here.
VITE_APP_NAME=LawPath SA
VITE_APP_URL=https://lawpath.example.co.za
# Leave blank when Apache proxies /api on the same domain.
VITE_API_BASE_URL=

# Future backend configuration.
# These belong on the Ubuntu server only, not in the Vite frontend bundle.
PORT=3001
NODE_ENV=production
DATABASE_URL=postgresql://lawpath:change_me@127.0.0.1:5432/lawpath
SESSION_SECRET=change_me_to_a_long_random_value
JWT_EXPIRES_IN=7d
SMTP_HOST=smtp.example.co.za
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=notifications@example.co.za
SMTP_PASSWORD=change_me
SMTP_FROM_EMAIL=notifications@example.co.za
SMTP_FROM_NAME=LawPath SA
OPENAI_API_KEY=change_me
GEMINI_API_KEY=change_me
GROK_API_KEY=change_me
EXCHANGERATES_API_KEY=change_me

# Google Cloud Storage for tenant media, legal documents and AI training data.
# Use either GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/service-account.json
# or GCS_CREDENTIALS_JSON='{"type":"service_account",...}' on the server.
GCS_BUCKET_NAME=lawpath-ai-training
GEMINI_GCS_BUCKET_NAME=lawpath-ai-training
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
GOOGLE_APPLICATION_CREDENTIALS=/home2/lawpath/secure/gcp-service-account.json
GCS_SIGNED_URLS=true
# Optional when the bucket or CDN is public:
# GCS_PUBLIC_BASE_URL=https://storage.googleapis.com/lawpath-ai-training
