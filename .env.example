# Frontend public configuration.
# Values prefixed with VITE_ are bundled into the browser build, so never put secrets here.
VITE_APP_NAME=LawPath SA
VITE_APP_URL=https://lawpath.example.co.za
# Leave blank when Apache proxies /api on the same domain.
VITE_API_BASE_URL=

# Future backend configuration.
# These belong on the Ubuntu server only, not in the Vite frontend bundle.
PORT=3001
NODE_ENV=production
DATABASE_URL=postgresql://lawpath:change_me@127.0.0.1:5432/lawpath
SESSION_SECRET=change_me_to_a_long_random_value
JWT_EXPIRES_IN=7d
SMTP_HOST=smtp.example.co.za
SMTP_PORT=587
SMTP_USERNAME=notifications@example.co.za
SMTP_PASSWORD=change_me
OPENAI_API_KEY=change_me
GEMINI_API_KEY=change_me
GROK_API_KEY=change_me
EXCHANGERATES_API_KEY=change_me
